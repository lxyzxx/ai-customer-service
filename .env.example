APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_PATH=data/app.db
RAG_TOP_K=4

# Optional: OpenAI-compatible chat completions endpoint, called through the OpenAI SDK.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: embedding and Qdrant vector search.
# EMBEDDING_PROVIDER can be `openai` for an OpenAI-compatible embeddings API,
# or `local` for sentence-transformers models such as BAAI/bge-m3.
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=internal_qa_chunks
